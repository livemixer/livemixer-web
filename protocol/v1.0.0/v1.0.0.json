        {
          "id": "pip_video",
          "type": "video",
          "source": "source_cam_1",
          "zIndex": 1,
          "layout": {
            "x": 0,
            "y": 0,
            "width": 480,
            "height": 270
          }
        },
        {
          "id": "pip_label",
          "type": "text",
          "content": "Presenter",
          "zIndex": 2,
          "layout": {
            "x": 10,
            "y": 10,
            "width": 100,
            "height": 30
          }
        }
      ]
    }
  ]
