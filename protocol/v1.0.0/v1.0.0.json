{
  "version": "1.0.0",
  "metadata": {
    "name": "My Live Streaming Layout",
    "createdAt": "2023-10-27T08:00:00.000Z",
    "updatedAt": "2023-10-27T10:00:00.000Z"
  },
  "canvas": {
    "width": 1920,
    "height": 1080
  },
  "resources": {
    "sources": [
      {
        "id": "source_cam_1",
        "type": "video_input",
        "name": "Main Camera",
        "config": {
          "deviceId": "default_video_1"
        }
      },
      {
        "id": "source_mic_1",
        "type": "audio_input",
        "name": "Lavalier Microphone",
        "config": {
          "deviceId": "default_audio_1"
        }
      },
      {
        "id": "bgm_track",
        "type": "audio_file",
        "name": "Background Music",
        "url": "./assets/bgm.mp3"
      }
    ]
  },
  "scenes": [
    {
      "id": "scene_welcome",
      "name": "Welcome Scene",
      "active": true,
      "transition": {
        "type": "fade",
        "duration": 500,
        "easing": "ease-in-out",
        "direction": "left"
      },
      "sourceStates": {
        "source_cam_1": {
          "visible": true,
          "muted": false
        },
        "source_mic_1": {
          "muted": false,
          "volume": 1.0
        },
        "bgm_track": {
          "muted": false,
          "volume": 0.3,
          "playbackStatus": "playing"
        }
      },
      "items": [
        {
          "id": "item_background",
          "type": "color",
          "zIndex": 0,
          "color": "#1a1a2e",
          "layout": {
            "x": 0,
            "y": 0,
            "width": 1920,
            "height": 1080
          }
        },
        {
          "id": "text-overlay",
          "type": "text",
          "content": "Welcome to My Live Stream!",
          "zIndex": 2,
          "layout": {
            "x": 150,
            "y": 600,
            "width": 400,
            "height": 50
          },
          "properties": {
            "fontSize": 24,
            "color": "#FFFFFF"
          }
        },
        {
          "id": "item_cam_full",
          "type": "video",
          "source": "source_cam_1",
          "zIndex": 1,
          "layout": {
            "x": 0,
            "y": 0,
            "width": 1920,
            "height": 1080
          },
          "transform": {
            "opacity": 1.0,
            "rotation": 0,
            "filters": [
              {
                "name": "brightness",
                "value": 1.2
              }
            ]
          }
        },
        {
          "id": "item_pip_container",
          "type": "scene_ref",
          "refSceneId": "pip_scene",
          "zIndex": 10,
          "layout": {
            "x": 1400,
            "y": 600,
            "width": 480,
            "height": 270
          },
          "transform": {
            "opacity": 0.9,
            "rotation": 0,
            "borderRadius": 10
          }
        }
      ]
    },
    {
      "id": "scene_demo",
      "name": "Product Demo",
      "active": false,
      "transition": {
        "type": "slide",
        "duration": 800,
        "direction": "right"
      },
      "items": [
        {
          "id": "item_pip_container",
          "type": "scene_ref",
          "refSceneId": "pip_scene",
          "zIndex": 10,
          "layout": {
            "x": 1400,
            "y": 600,
            "width": 480,
            "height": 270
          },
          "transform": {
            "opacity": 0.9,
            "rotation": 0,
            "borderRadius": 10
          }
        },
        {
          "id": "screen-1",
          "type": "screen",
          "source": "window:chrome",
          "zIndex": 1,
          "layout": {
            "x": 800,
            "y": 100,
            "width": 1024,
            "height": 768
          }
        },
        {
          "id": "main-scene",
          "type": "container",
          "zIndex": 3,
          "layout": {
            "x": 0,
            "y": 0,
            "width": 1920,
            "height": 1080
