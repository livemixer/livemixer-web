{
  "name": "livemixer-web",
  "private": false,
  "version": "0.0.1",
  "type": "module",
  "description": "An open-source live video mixer and streaming application based on LiveKit RTC",
  "author": "LiveMixer Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/livemixer/livemixer-web.git"
  },
  "keywords": [
    "live-streaming",
    "video-mixer",
    "livekit",
    "obs-alternative",
    "react",
    "konva"
  ],
  "main": "./dist/livemixer-web.umd.js",
  "module": "./dist/livemixer-web.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/livemixer-web.es.js",
      "require": "./dist/livemixer-web.umd.js"
    },
    "./dist/livemixer-web.css": "./dist/livemixer-web.css",
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --mode lib && tsc --project tsconfig.lib.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "konva": "^10.0.12",
    "livekit-client": "^2.16.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-konva": "^19.2.1",
    "tailwind-merge": "^3.4.0",
    "use-image": "^1.1.4",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.9.3",
    "vite": "^7.2.4"
  }
}